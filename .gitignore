# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Virtual envs ----
.venv/
venv/
env/

# ---- IDE / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ---- Hearth runtime artifacts ----
# Never commit a user's voice models, screenshots, logs, or memory.
# These live in ~/Jarvis/ by default, but if anyone points JARVIS_WORKSPACE
# at the project dir we still don't want this in git.
voices/
screenshots/
logs/
*.jsonl
*.onnx
*.bin

# ---- Reference / scavenge repos (Ishant keeps these locally for inspiration) ----
# NOT ours to redistribute — these must NEVER be committed/published.
clawdbot-main/
openhuman-main/
hermes-agent-main/
graphify-7/
superpowers-main/
oh-my-openagent-dev/
openclaw-main/
claude-code-main/
skill-creator/
awesome-openclaw-skills-main/
# Catch-all for any other downloaded reference repo sitting beside Hearth.
*-main/
*-dev/

# ---- Bundled Windows Terminal binaries (Microsoft's, not ours to redistribute) ----
Windows Terminal/
Terminal/

# ---- Local user state ----
.env
.env.local
*.local
secrets.*
# Personal cloud-launcher scripts contain a raw API key — never commit them.
gemini.ps1
grok.ps1
*-secret.ps1

# ---- Build / dist ----
build/
dist/
*.egg
build_log.txt

# ---- Misc ----
*.log
.coverage
htmlcov/
.tox/
.claude/

# ---- Historical / superseded docs (kept locally, not shipped) ----
